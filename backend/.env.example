# === ОБЯЗАТЕЛЬНЫЕ ===

# База данных (SQLite для dev, PostgreSQL для prod)
DATABASE_URL="file:./dev.db"

# Redis (Upstash или локальный)
REDIS_URL="rediss://..."

# Секрет для JWT токенов — минимум 32 случайных символа
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret"

# Ключ шифрования API ключей в БД — РОВНО 32 символа
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY="change-this-to-32-character-key!"

# === ОПЦИОНАЛЬНЫЕ ===

# Порт backend (по умолчанию 3000)
PORT=3000

# URL фронтенда для OAuth редиректов (по умолчанию localhost:5173)
FRONTEND_URL="http://localhost:5173"

# Google Drive OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/storage/google/callback"

# Yandex Disk OAuth
YANDEX_CLIENT_ID=""
YANDEX_CLIENT_SECRET=""
YANDEX_REDIRECT_URI="http://localhost:3000/storage/yandex/callback"
